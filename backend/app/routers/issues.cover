    1: router = APIRouter(prefix="/api/issues", tags=["issues"])
       
    1: VALID_STATUSES = {"BACKLOG", "TODO", "IN_PROGRESS", "IN_REVIEW", "DONE", "BLOCKED"}
    1: VALID_TYPES = {"TASK", "BUG", "STORY", "EPIC", "IMPROVEMENT"}
    1: VALID_PRIORITIES = {"LOW", "MEDIUM", "HIGH", "URGENT"}
       
       
   28: class IssueCreate(BaseModel):
    3:     project_id: str | None = None
