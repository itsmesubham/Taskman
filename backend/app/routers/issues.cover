    1:         (payload.status, position, issue_id, tenant_id),
           )
    1:     record_activity(tenant_id, current_user["id"], "issue_status_changed", f"Moved {updated['issue_key']} to {payload.status}", project_id=updated["project_id"], issue_id=issue_id, metadata={"from": issue["status"], "to": payload.status})
    1:     await event_bus.publish(tenant_id, "issue_updated", {"issue": row_to_json(updated), "changes": {"status": payload.status, "position": position}})
    1:     return {"issue": row_to_json(updated)}
       
       
    2: @router.patch("/{issue_id}/sprint")
    3: async def update_sprint(issue_id: str, payload: SprintAssignment, current_user: dict = Depends(get_current_user)):
