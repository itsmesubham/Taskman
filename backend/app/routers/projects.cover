    2: @router.patch("/{project_id}")
    3: async def update_project(project_id: str, payload: ProjectUpdate, current_user: dict = Depends(get_current_user)):
    1:     tenant_id = resolve_tenant_id(current_user)
    1:     project = fetch_one("SELECT id, tenant_id, name, key, description, visibility, status, issue_counter, created_by, created_at, updated_at FROM projects WHERE id = %s AND tenant_id = %s", (project_id, tenant_id))
    1:     if not project:
               raise HTTPException(status_code=404, detail="Project not found")
    1:     if current_user["role"] not in ("OWNER", "ADMIN") and project.get("created_by") != current_user["id"]:
               raise HTTPException(status_code=403, detail="Insufficient permissions")
    1:     name = payload.name.strip() if payload.name is not None else project["name"]
    1:     description = payload.description if payload.description is not None else project["description"]
    1:     status = payload.status if payload.status is not None else project["status"]
    1:     visibility = payload.visibility if payload.visibility is not None else project.get("visibility", "EVERYONE")
    2:     updated = execute(
    1:         """
               UPDATE projects SET name = %s, description = %s, status = %s, visibility = %s, updated_at = now()
               WHERE id = %s AND tenant_id = %s
               RETURNING *
               """,
    1:         (name, description, status, visibility, project_id, tenant_id),
           )
    1:     record_activity(tenant_id, current_user["id"], "project_updated", f"Updated project {updated['key']}", project_id=project_id)
    1:     await event_bus.publish(str(tenant_id), "project_updated", {"project": row_to_json(updated)})
    1:     return {"project": row_to_json(updated)}
       
       
    2: @router.delete("/{project_id}")
    3: async def archive_project(project_id: str, current_user: dict = Depends(get_current_user)):
    2:     tenant_id = resolve_tenant_id(current_user)
    2:     project = fetch_one("SELECT id, tenant_id, name, key, description, visibility, status, issue_counter, created_by, created_at, updated_at FROM projects WHERE id = %s AND tenant_id = %s", (project_id, tenant_id))
    2:     if not project:
               raise HTTPException(status_code=404, detail="Project not found")
    2:     if current_user["role"] not in ("OWNER", "ADMIN") and project.get("created_by") != current_user["id"]:
    1:         raise HTTPException(status_code=403, detail="Insufficient permissions")
    2:     updated = execute(
    1:         """
               UPDATE projects
               SET status = 'ARCHIVED', updated_at = now()
               WHERE id = %s
                 AND tenant_id = %s
                 AND (%s IN ('OWNER', 'ADMIN') OR created_by = %s)
               RETURNING *
               """,
    1:         (project_id, tenant_id, current_user["role"], current_user["id"]),
           )
    1:     if not updated:
               raise HTTPException(status_code=404, detail="Project not found")
    1:     record_activity(tenant_id, current_user["id"], "project_archived", f"Archived project {updated['key']}", project_id=project_id)
    1:     await event_bus.publish(str(tenant_id), "project_archived", {"project_id": project_id})
    1:     return {"ok": True}
