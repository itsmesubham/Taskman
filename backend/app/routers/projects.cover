               raise HTTPException(status_code=400, detail="Workspace not selected")
    1:     return str(tenant_id)
       
       
    2: @router.get("")
    3: def list_projects(current_user: dict = Depends(get_current_user), include_archived: bool = False):
    2:     tenant_id = resolve_tenant_id(current_user)
    2:     if include_archived:
    1:         rows = fetch_all("SELECT id, tenant_id, name, key, description, visibility, status, issue_counter, created_by, created_at, updated_at FROM projects WHERE tenant_id = %s ORDER BY created_at DESC", (tenant_id,))
           else:
    1:         rows = fetch_all("SELECT id, tenant_id, name, key, description, visibility, status, issue_counter, created_by, created_at, updated_at FROM projects WHERE tenant_id = %s AND status != 'ARCHIVED' ORDER BY created_at DESC", (tenant_id,))
    2:     return {"projects": rows_to_json(rows)}
       
       
    2: @router.post("")
    3: async def create_project(payload: ProjectCreate, current_user: dict = Depends(get_current_user)):
    3:     tenant_id = resolve_tenant_id(current_user)
    3:     key = project_key(payload.key or payload.name)
    3:     try:
    6:         with get_conn() as conn:
    6:             with conn.cursor() as cur:
    6:                 cur.execute(
    3:                     """
                           INSERT INTO projects (tenant_id, name, key, description, visibility, created_by)
                           VALUES (%s, %s, %s, %s, %s, %s)
                           ON CONFLICT (tenant_id, key)
                           DO NOTHING
                           RETURNING *
                           """,
    3:                     (tenant_id, payload.name.strip(), key, payload.description, payload.visibility, current_user["id"]),
                       )
    3:                 project = cur.fetchone()
    3:                 if not project:
    2:                     cur.execute("SELECT id, tenant_id, name, key, description, visibility, status, issue_counter, created_by, created_at, updated_at FROM projects WHERE tenant_id = %s AND key = %s LIMIT 1", (tenant_id, key))
    2:                     project = cur.fetchone()
           except Exception as exc:
               code = getattr(exc, "sqlstate", None)
               if code == "23505":
                   raise HTTPException(status_code=409, detail="Project key already exists in this tenant")
               raise
    3:     if not project:
               raise HTTPException(status_code=500, detail="Project creation failed")
    3:     record_activity(tenant_id, current_user["id"], "project_created", f"Created project {project['key']}", project_id=project["id"])
    3:     await event_bus.publish(str(tenant_id), "project_created", {"project": row_to_json(project)})
    3:     return {"project": row_to_json(project)}
       
       
    2: @router.get("/{project_id}")
    3: def get_project(project_id: str, current_user: dict = Depends(get_current_user)):
           tenant_id = resolve_tenant_id(current_user)
           project = fetch_one("SELECT id, tenant_id, name, key, description, visibility, status, issue_counter, created_by, created_at, updated_at FROM projects WHERE id = %s AND tenant_id = %s", (project_id, tenant_id))
           if not project:
               raise HTTPException(status_code=404, detail="Project not found")
