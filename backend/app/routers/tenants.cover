    2: @router.get("/{tenant_id}/members")
    3: def members(tenant_id: str, current_user: dict = Depends(get_current_user)):
    1:     if resolve_tenant_id(current_user) != tenant_id:
               raise HTTPException(status_code=403, detail="Cannot access another tenant")
    2:     rows = fetch_all(
    1:         """
               SELECT u.id, u.name, u.email, tm.role, tm.status, tm.joined_at
               FROM tenant_members tm
               JOIN users u ON u.id = tm.user_id
               WHERE tm.tenant_id = %s
               ORDER BY tm.joined_at ASC
               """,
    1:         (tenant_id,),
           )
    1:     return {"members": rows_to_json(rows)}
       
       
    2: @router.get("/{tenant_id}/invite-link")
    3: def get_invite_link(tenant_id: str, current_user: dict = Depends(require_role("OWNER", "ADMIN"))):
    1:     if resolve_tenant_id(current_user) != tenant_id:
               raise HTTPException(status_code=403, detail="Cannot access another tenant")
    1:     tenant = ensure_workspace_invite(tenant_id)
