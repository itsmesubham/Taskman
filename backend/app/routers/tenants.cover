               raise HTTPException(status_code=404, detail="Workspace not found")
    1:     return {
    1:         "tenant": row_to_json(tenant),
    1:         "invite_url": invite_url_for_tenant(tenant),
           }
       
       
    2: @router.post("/{tenant_id}/invite-link/regenerate")
    3: def regenerate_invite_link(tenant_id: str, current_user: dict = Depends(require_role("OWNER", "ADMIN"))):
    1:     if resolve_tenant_id(current_user) != tenant_id:
               raise HTTPException(status_code=403, detail="Cannot access another tenant")
