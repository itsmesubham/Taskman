    2: @router.post("/{tenant_id}/invite-link/revoke")
    3: def revoke_invite_link(tenant_id: str, current_user: dict = Depends(require_role("OWNER", "ADMIN"))):
    1:     if resolve_tenant_id(current_user) != tenant_id:
               raise HTTPException(status_code=403, detail="Cannot access another tenant")
    2:     tenant = execute(
