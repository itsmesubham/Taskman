           }
       
       
    2: @router.post("/login")
    3: def login(payload: LoginRequest):
    1:     email = normalize_email(payload.email)
    2:     row = fetch_one(
    1:         "SELECT id, name, email, password_hash, active_tenant_id FROM users WHERE email = %s",
    1:         (email,),
           )
    1:     if not row or not verify_password(payload.password, row["password_hash"]):
               raise HTTPException(status_code=status.HTTP_401_UNAUTHORIZED, detail="Invalid credentials")
    1:     memberships = rows_to_json(memberships_for_user(str(row["id"])))
    1:     return {
