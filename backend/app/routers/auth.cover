           })
       
       
    2: @router.post("/signup")
    3: def signup(payload: SignupRequest):
    2:     email = normalize_email(payload.email)
    4:     with get_conn() as conn:
    4:         with conn.cursor() as cur:
    2:             cur.execute("SELECT id, name, email, password_hash, active_tenant_id FROM users WHERE email = %s", (email,))
    2:             user = cur.fetchone()
    2:             if user:
    1:                 if not verify_password(payload.password, user["password_hash"]):
    1:                     raise HTTPException(status_code=409, detail="Email already exists with a different password")
                   else:
    2:                 cur.execute(
    1:                     "INSERT INTO users (name, email, password_hash) VALUES (%s, %s, %s) RETURNING *",
    1:                     (payload.name.strip(), email, hash_password(payload.password)),
                       )
    1:                 user = cur.fetchone()
       
    1:     memberships = rows_to_json(memberships_for_user(str(user["id"])))
    1:     return {
